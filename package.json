		],
		"nodes": [
			"dist/nodes/Gladia/Gladia.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "*",
		"@types/jest": "^29.5.14",
		"eslint": "9.32.0",
		"jest": "^29.7.0",
		"prettier": "3.6.2",
		"release-it": "^20.0.1",
		"ts-jest": "^29.4.9",
		"typescript": "5.9.2"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	},
	"overrides": {
		"axios": "^1.16.0",
		"follow-redirects": "^1.16.0",
		"basic-ftp": "^5.3.0",
		"langsmith": "^0.6.0",
		"defu": "^6.1.5",
		"lodash": "^4.18.0",
		"handlebars": "^4.7.9",
		"picomatch": "^4.0.4",
		"yaml": "^2.8.3",
