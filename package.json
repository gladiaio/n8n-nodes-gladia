{
	"name": "@gladiaio/n8n-nodes-gladia",
	"version": "0.1.6",
	"description": "Gladia Speech to Text Node",
	"license": "MIT",
	"homepage": "https://github.com/gladiaio/n8n-nodes-gladia#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/gladiaio/n8n-nodes-gladia.git"
	},
	"publishConfig": {
		"access": "public"
	},
	"keywords": [
		"n8n-community-node-package",
		"gladia",
		"speech-to-text",
		"transcription",
		"audio",
		"audio-transcription",
		"asr",
		"automatic-speech-recognition",
		"ai",
		"translation",
		"subtitles",
		"captions",
		"real-time",
		"voice",
		"multilingual"
	],
	"author": {
		"name": "Gladia",
		"email": "support@gladia.io"
	},
	"scripts": {
		"build": "n8n-node build",
		"build:watch": "tsc --watch",
		"dev": "n8n-node dev",
		"lint": "node scripts/run-without-overrides.mjs n8n-node lint",
		"lint:fix": "node scripts/run-without-overrides.mjs n8n-node lint --fix",
		"release": "n8n-node release",
		"strip-overrides": "node scripts/strip-overrides.mjs",
		"test": "jest"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": true,
		"credentials": [
			"dist/credentials/GladiaApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/Gladia/Gladia.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "*",
		"@types/jest": "^29.5.14",
		"eslint": "9.32.0",
		"jest": "^29.7.0",
		"prettier": "3.6.2",
		"release-it": "^20.0.1",
		"ts-jest": "^29.4.9",
		"typescript": "5.9.2"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
}
