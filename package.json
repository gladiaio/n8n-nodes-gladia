{
	"name": "@gladiaio/n8n-nodes-gladia",
	"version": "0.1.0",
	"description": "Gladia Speech to Text Node",
	"license": "MIT",
	"homepage": "https://github.com/gladiaio/n8n-nodes-gladia#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/gladiaio/n8n-nodes-gladia.git"
	},
	"publishConfig": {
		"access": "public"
	},
	"keywords": [
		"n8n-community-node-package",
		"gladia",
		"speech-to-text",
		"transcription",
		"audio",
		"audio-transcription",
		"asr",
		"automatic-speech-recognition",
		"ai",
		"translation",
		"subtitles",
		"captions",
		"real-time",
		"voice",
		"multilingual"
	],
	"author": {
		"name": "Gladia",
		"email": "support@gladia.io"
	},
	"scripts": {
		"build": "n8n-node build",
		"build:watch": "tsc --watch",
		"dev": "n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"release": "n8n-node release",
		"test": "jest"
	},
	"files": [
		"dist"
	],
	"n8n": {
