		"tmp": "^0.2.6",
		"brace-expansion@5": "^5.0.6",
		"ws@^8": "^8.20.1",
		"js-yaml": "^4.2.0",
		"@babel/core": "^7.29.6",
		"form-data": "^4.0.6",
		"@langchain/community": "^1.1.18",
		"eslint-plugin-n8n-nodes-base": {
			"@typescript-eslint/utils": {
